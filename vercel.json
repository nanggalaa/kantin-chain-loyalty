{
  "buildCommand": "npm run build",
  "outputDirectory": "dist/client",
  "framework": null,
  "env": {
    "NITRO_PRESET": "vercel"
  },
  "rewrites": [
    {
      "source": "/(.*)",
      "destination": "/api/server"
    }
  ],
  "functions": {
    "api/server.js": {
      "memory": 512,
      "maxDuration": 30
    }
  }
}
